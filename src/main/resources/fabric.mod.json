{
	"schemaVersion": 1,
	"id": "unknown-enchants",
	"version": "${version}",
	"name": "Unknown Enchants",
	"description": "Obfuscates undiscovered enchants",
	"authors": [
		"Bee :3"
	],
	"contact": {
		"sources": "https://github.com/Tricangel/Unknown-Enchants",
		"issues": "https://github.com/Tricangel/Unknown-Enchants/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/unknown-enchants/icon.png",
	"environment": "*",
	"entrypoints": {
