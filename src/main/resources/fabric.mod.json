		"unknown-enchants:discovered_enchants"
		]
	},
	"mixins": [
      "unknown-enchants.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
